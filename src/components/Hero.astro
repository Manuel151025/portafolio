---
/**
 * Hero.astro — Sección de portada (dos columnas).
 * Izquierda: badge de disponibilidad, rol, nombre (h1), CTAs y descripción.
 * Derecha: la credencial colgante. Indicador de scroll abajo.
 * Ver CLAUDE.md §7 y §8. Sin tagline (por decisión de diseño).
 */
import IdCard from "./IdCard.astro";
---

<section class="hero" id="hero">
  <div class="hero__inner container">
    <div class="hero__content">
      <p class="hero__badge">
        <span class="hero__badge-dot" aria-hidden="true"></span>
        Disponible para trabajar
      </p>

      <p class="hero__eyebrow">Analista y Desarrollador de Software</p>

      <h1 class="hero__title">
        Manuel Andrés<br />
        <span class="accent">Cárdenas Suárez</span>
      </h1>

      <div class="hero__actions">
        <a class="btn btn--primary" href="#projects">Ver proyectos</a>
        <button class="btn btn--ghost" type="button" id="cv-open">Ver CV</button>
      </div>

      <p class="hero__lead">
        Desarrollo aplicaciones web y móviles con foco en arquitectura limpia
        y buenas prácticas. Del análisis al despliegue.
      </p>
    </div>

    <div class="hero__visual">
      <IdCard />
    </div>
  </div>

  <div class="hero__scroll" aria-hidden="true">
    <span class="hero__scroll-text">Desplázate</span>
    <span class="hero__scroll-arrow">↓</span>
  </div>
</section>

<dialog
  class="cv-dialog"
  id="cv-dialog"
  aria-label="Curriculum Vitae de Manuel Cárdenas"
>
  <div class="cv-dialog__bar">
    <span class="cv-dialog__title">Curriculum Vitae</span>
    <div class="cv-dialog__actions">
      <div class="cv-lang" role="group" aria-label="Idioma del CV">
        <button
          class="cv-lang__btn is-active"
          type="button"
          data-lang="es">ES</button>
        <button class="cv-lang__btn" type="button" data-lang="en">EN</button>
      </div>
      <button class="cv-btn" type="button" id="cv-print">Imprimir</button>
      <a class="cv-btn" id="cv-download" href="/cv.pdf" download>Descargar</a>
      <button class="cv-btn cv-btn--close" type="button" id="cv-close">
        Volver al portafolio
      </button>
    </div>
  </div>
  <div class="cv-dialog__viewer">
    <iframe
      class="cv-dialog__frame"
      data-src="/cv.pdf#toolbar=0&navpanes=0&view=FitH"
      title="Curriculum Vitae de Manuel Cárdenas"
    ></iframe>
  </div>
</dialog>

<script>
  import "../scripts/hero-scroll.js";
  import "../scripts/cv-viewer.js";
</script>
