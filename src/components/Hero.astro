---
/**
 * Hero.astro — Sección de portada (dos columnas).
 * Izquierda: badge de disponibilidad, rol, nombre (h1), CTAs y descripción.
 * Derecha: la credencial colgante. Indicador de scroll abajo.
 * Ver CLAUDE.md §7 y §8. Sin tagline (por decisión de diseño).
 */
import IdCard from "./IdCard.astro";
---

<section class="hero" id="hero">
  <div class="hero__inner container">
    <div class="hero__content">
      <p class="hero__badge">
        <span class="hero__badge-dot" aria-hidden="true"></span>
        Disponible para trabajar
      </p>

      <p class="hero__eyebrow">Analista y Desarrollador de Software</p>

      <h1 class="hero__title">
        Manuel Andrés<br />
        <span class="accent">Cárdenas Suárez</span>
      </h1>

      <div class="hero__actions">
        <a class="btn btn--primary" href="#projects">Ver proyectos</a>
        <a class="btn btn--ghost" href="/cv.pdf" download>Descargar CV</a>
      </div>

      <p class="hero__lead">
        Desarrollo aplicaciones web y móviles con foco en arquitectura limpia
        y buenas prácticas. Del análisis al despliegue.
      </p>
    </div>

    <div class="hero__visual">
      <IdCard />
    </div>
  </div>

  <div class="hero__scroll" aria-hidden="true">
    <span class="hero__scroll-text">Desplázate</span>
    <span class="hero__scroll-arrow">↓</span>
  </div>
</section>

<script>
  import "../scripts/hero-scroll.js";
</script>
