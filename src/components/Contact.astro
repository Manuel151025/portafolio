---
/**
 * Contact.astro — Contacto: formulario + iconos de redes.
 * El formulario se envía con Web3Forms (servicio gratuito, sin backend);
 * la lógica y validación están en scripts/contact-form.js. Los canales son
 * iconos de marca monocromáticos (simple-icons). Ver CLAUDE.md §7 y §8.
 *
 * ⚠️ WEB3FORMS_KEY: tu access key gratuita de https://web3forms.com
 */
import { Icon } from "astro-icon/components";

const WEB3FORMS_KEY = "170da6a0-f313-46e2-9b78-a4ac222794ee";

const socials = [
  {
    label: "Escríbeme por correo",
    icon: "simple-icons:gmail",
    href: "mailto:Manuelcardenassuarez2005@gmail.com",
    external: false,
  },
  {
    label: "GitHub",
    icon: "simple-icons:github",
    href: "https://github.com/Manuel151025",
    external: true,
  },
  {
    label: "LinkedIn",
    icon: "simple-icons:linkedin",
    href: "https://www.linkedin.com/in/manuel-cardenas-89b03b424",
    external: true,
  },
  {
    label: "WhatsApp",
    icon: "simple-icons:whatsapp",
    href: "https://wa.me/573209891830",
    external: true,
  },
];
---

<section class="section contact" id="contact">
  <div class="container">
    <header class="section__head">
      <span class="section__index reveal">04 —</span>
      <h2 class="section__title reveal-wipe">Contacto</h2>
    </header>

    <div class="contact__inner">
      <div class="contact__form-col reveal">
        <p class="contact__lead">
          ¿Tienes un proyecto en mente o una vacante que encaje? Hablemos.
        </p>

        <form class="contact-form" id="contact-form">
          <input type="hidden" name="access_key" value={WEB3FORMS_KEY} />
          <input
            type="hidden"
            name="from_name"
            value="Portafolio · manuelcardenas.online"
          />
          <!-- Honeypot antispam (oculto para personas) -->
          <input
            type="checkbox"
            name="botcheck"
            class="visually-hidden"
            tabindex="-1"
            autocomplete="off"
            aria-hidden="true"
          />

          <div class="form-row">
            <div class="field">
              <label for="cf-name">Nombre</label>
              <input
                id="cf-name"
                type="text"
                name="name"
                required
                minlength="2"
                maxlength="80"
                autocomplete="name"
                placeholder="Tu nombre"
              />
            </div>

            <div class="field">
              <label for="cf-email">Email</label>
              <input
                id="cf-email"
                type="email"
                name="email"
                required
                maxlength="120"
                autocomplete="email"
                placeholder="tucorreo@ejemplo.com"
              />
            </div>
          </div>

          <div class="field">
            <label for="cf-subject">Asunto</label>
            <input
              id="cf-subject"
              type="text"
              name="subject"
              maxlength="100"
              placeholder="¿De qué se trata?"
            />
          </div>

          <div class="field">
            <label for="cf-message">Mensaje</label>
            <textarea
              id="cf-message"
              name="message"
              required
              minlength="10"
              maxlength="1000"
              rows="5"
              placeholder="Cuéntame en qué puedo ayudarte…"></textarea>
            <span class="field__counter" aria-hidden="true">0 / 1000</span>
          </div>

          <button class="btn btn--primary contact-form__submit" type="submit">
            Enviar mensaje
          </button>
          <p class="contact-form__status" role="status" aria-live="polite"></p>
        </form>
      </div>

      <div class="contact__connect reveal">
        <p class="contact__connect-label">Conéctate</p>
        <p class="contact__connect-note">
          Escríbeme por el canal que prefieras.
        </p>
        <ul class="social">
          {
            socials.map((s) => (
              <li>
                <a
                  class="social__link"
                  href={s.href}
                  aria-label={s.label}
                  title={s.label}
                  {...(s.external
                    ? { target: "_blank", rel: "noopener noreferrer" }
                    : {})}
                >
                  <Icon name={s.icon} />
                </a>
              </li>
            ))
          }
        </ul>

        <dl class="contact__info">
          <div class="contact__info-row">
            <dt>Ubicación</dt>
            <dd>Colombia · Remoto</dd>
          </div>
          <div class="contact__info-row">
            <dt>Horario</dt>
            <dd>GMT-5 (COT)</dd>
          </div>
          <div class="contact__info-row">
            <dt>Estado</dt>
            <dd>
              <span class="contact__info-dot" aria-hidden="true"></span>
              Abierto a propuestas
            </dd>
          </div>
        </dl>
      </div>
    </div>
  </div>
</section>

<script>
  import "../scripts/contact-form.js";
</script>
