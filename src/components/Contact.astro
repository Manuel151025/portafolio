---
/**
 * Contact.astro — Contacto: formulario + canales directos.
 * El formulario se envía con Web3Forms (servicio gratuito, sin backend);
 * la lógica está en scripts/contact-form.js. Ver CLAUDE.md §7 y §8.
 *
 * ⚠️ CONFIGURACIÓN: reemplaza WEB3FORMS_KEY por tu access key gratuita.
 *    La obtienes en https://web3forms.com poniendo tu correo (30 s).
 *    Hasta entonces, el formulario mostrará un error al enviar (los
 *    canales directos de la derecha siguen funcionando).
 */
const WEB3FORMS_KEY = "170da6a0-f313-46e2-9b78-a4ac222794ee";

const channels = [
  {
    label: "Email",
    value: "Manuelcardenassuarez2005@gmail.com",
    href: "mailto:Manuelcardenassuarez2005@gmail.com",
    external: false,
  },
  {
    label: "GitHub",
    value: "@Manuel151025",
    href: "https://github.com/Manuel151025",
    external: true,
  },
  {
    label: "LinkedIn",
    value: "in/manuel-cardenas",
    href: "https://www.linkedin.com/in/manuel-cardenas-89b03b424",
    external: true,
  },
  {
    label: "Teléfono",
    value: "+57 320 989 1830",
    href: "tel:+573209891830",
    external: false,
  },
];
---

<section class="section contact" id="contact">
  <div class="container">
    <header class="section__head">
      <span class="section__index reveal">04 —</span>
      <h2 class="section__title reveal-wipe">Contacto</h2>
    </header>

    <div class="contact__inner">
      <div class="contact__form-col reveal">
        <p class="contact__lead">
          ¿Tienes un proyecto en mente o una vacante que encaje? Hablemos.
        </p>

        <form class="contact-form" id="contact-form">
          <input type="hidden" name="access_key" value={WEB3FORMS_KEY} />
          <input
            type="hidden"
            name="subject"
            value="Nuevo mensaje desde el portafolio"
          />
          <input
            type="hidden"
            name="from_name"
            value="Portafolio · manuelcardenas.online"
          />
          <!-- Honeypot antispam (oculto para personas) -->
          <input
            type="checkbox"
            name="botcheck"
            class="visually-hidden"
            tabindex="-1"
            autocomplete="off"
            aria-hidden="true"
          />

          <div class="field">
            <label for="cf-name">Nombre</label>
            <input
              id="cf-name"
              type="text"
              name="name"
              required
              autocomplete="name"
              placeholder="Tu nombre"
            />
          </div>

          <div class="field">
            <label for="cf-email">Email</label>
            <input
              id="cf-email"
              type="email"
              name="email"
              required
              autocomplete="email"
              placeholder="tucorreo@ejemplo.com"
            />
          </div>

          <div class="field">
            <label for="cf-message">Mensaje</label>
            <textarea
              id="cf-message"
              name="message"
              rows="5"
              required
              placeholder="Cuéntame en qué puedo ayudarte…"></textarea>
          </div>

          <button class="btn btn--primary contact-form__submit" type="submit">
            Enviar mensaje
          </button>
          <p class="contact-form__status" role="status" aria-live="polite"></p>
        </form>
      </div>

      <ul class="contact__channels">
        {
          channels.map((channel, i) => (
            <li class="reveal" style={`--reveal-delay: ${i * 70}ms`}>
              <a
                class="contact__channel"
                href={channel.href}
                {...(channel.external
                  ? { target: "_blank", rel: "noopener noreferrer" }
                  : {})}
              >
                <span class="contact__channel-label">{channel.label}</span>
                <span class="contact__channel-value">
                  {channel.value}
                  {channel.external && <span aria-hidden="true"> ↗</span>}
                </span>
              </a>
            </li>
          ))
        }
      </ul>
    </div>
  </div>
</section>

<script>
  import "../scripts/contact-form.js";
</script>
