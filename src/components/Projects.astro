---
/**
 * Projects.astro — Sección de proyectos.
 * Itera sobre la fuente única (data/projects.js) y renderiza una
 * ProjectCard por proyecto. Ver CLAUDE.md §7.
 */
import { projects } from "../data/projects.js";
import ProjectCard from "./ProjectCard.astro";
---

<section class="section projects" id="projects">
  <div class="container">
    <header class="section__head">
      <span class="section__index reveal">03 —</span>
      <h2 class="section__title reveal-wipe">Proyectos</h2>
    </header>

    <div class="projects__grid">
      {
        projects.map((proyecto, i) => (
          <ProjectCard proyecto={proyecto} index={i} />
        ))
      }
    </div>
  </div>
</section>
