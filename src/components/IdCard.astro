---
/**
 * IdCard.astro — Credencial colgante (elemento protagonista del Hero).
 * Solo HTML (template). La interactividad vive en scripts/card-tilt.js
 * (tilt 3D + coordinación con el balanceo) y los estilos en components.css.
 * El balanceo en reposo es CSS (animación sway). Ver CLAUDE.md §5 y §8.
 *
 * La foto (public/img/perfil.webp, 3:4) usa loading=eager + fetchpriority
 * por ser parte del LCP. El QR se genera en build (qrcode) y apunta a GitHub.
 */
import QRCode from "qrcode";

const domain = "manuelcardenas.online";
const githubUrl = "https://github.com/Manuel151025";
const qrSvg = await QRCode.toString(githubUrl, {
  type: "svg",
  margin: 0,
  errorCorrectionLevel: "M",
  color: { dark: "#0a0a0b", light: "#f5f5f7" },
});
---

<div class="id-card-scene">
  <!-- Cordón (lanyard): dos cintas en V que se unen en el clip -->
  <div class="lanyard" aria-hidden="true">
    <span class="lanyard__strap lanyard__strap--left">{domain} · {domain}</span>
    <span class="lanyard__strap lanyard__strap--right">{domain} · {domain}</span>
    <span class="lanyard__clip"></span>
  </div>

  <article class="id-card" data-tilt aria-label="Carnet de desarrollador">
    <div class="id-card__sheen" aria-hidden="true"></div>

    <header class="id-card__header">
      <span>Software Dev</span>
      <span class="id-card__id">DEV-2026</span>
    </header>

    <div class="id-card__photo">
      <img
        src="/img/perfil.webp"
        alt="Manuel Andrés Cárdenas Suárez"
        width="900"
        height="1200"
        loading="eager"
        fetchpriority="high"
        decoding="async"
      />
    </div>

    <div class="id-card__info">
      <p class="id-card__name">Manuel A. Cárdenas</p>
      <p class="id-card__role">Analista &amp; Desarrollador de Software</p>
    </div>

    <footer class="id-card__footer">
      <button
        class="id-card__qr"
        type="button"
        aria-label="Ampliar el QR de mi GitHub"
        set:html={qrSvg}
      ></button>
      <span class="id-card__handle">@Manuel151025</span>
    </footer>
  </article>
</div>

<dialog class="tech-dialog qr-dialog" id="qr-dialog" aria-labelledby="qr-dialog-title">
  <div class="tech-dialog__inner qr-dialog__inner">
    <button class="tech-dialog__close" type="button" aria-label="Cerrar">
      <span aria-hidden="true">×</span>
    </button>
    <h3 class="tech-dialog__title" id="qr-dialog-title">Escanea mi GitHub</h3>
    <div class="qr-dialog__code" set:html={qrSvg}></div>
    <a
      class="qr-dialog__link"
      href={githubUrl}
      target="_blank"
      rel="noopener noreferrer"
    >
      github.com/Manuel151025 <span aria-hidden="true">↗</span>
    </a>
  </div>
</dialog>

<script>
  import "../scripts/card-tilt.js";
  import "../scripts/qr-modal.js";
</script>
