---
/**
 * About.astro — Sección "Sobre mí".
 * Perfil + bloque de trabajo asistido por IA + áreas de enfoque.
 * Contenido literal según CLAUDE.md §8; las áreas resumen su stack real.
 */
import { Icon } from "astro-icon/components";

const focus = [
  {
    icon: "simple-icons:php",
    title: "Aplicaciones web",
    desc: "Backend con PHP 8 y MySQL 8, APIs REST y frontend responsivo con Bootstrap.",
  },
  {
    icon: "simple-icons:kotlin",
    title: "Móvil nativo",
    desc: "Android con Kotlin y Jetpack Compose; apps offline-first y Clean Architecture.",
  },
  {
    icon: "simple-icons:docker",
    title: "DevOps & despliegue",
    desc: "Docker, Dokploy y Nginx sobre Linux: del código a producción sin fricción.",
  },
  {
    icon: "simple-icons:git",
    title: "Buenas prácticas",
    desc: "Arquitectura limpia, código mantenible y control de versiones con Git.",
  },
];
---

<section class="section about" id="about">
  <div class="container">
    <header class="section__head">
      <span class="section__index reveal">01 —</span>
      <h2 class="section__title reveal-wipe">Sobre mí</h2>
    </header>

    <div class="about__grid">
      <p class="about__lead reveal">
        <strong>Analista y Desarrollador de Software.</strong> Desarrollo
        aplicaciones web y móviles con foco en arquitectura limpia, código
        mantenible y buenas prácticas. Trabajo principalmente con PHP 8 y
        MySQL 8 en el backend, JavaScript y Bootstrap en el frontend, y Kotlin
        con Jetpack Compose para desarrollo móvil nativo. En infraestructura
        administro despliegues con Docker y Dokploy sobre servidores Linux,
        usando Git y GitHub para el control de versiones.
      </p>

      <aside class="about__ai reveal" style="--reveal-delay: 120ms">
        <p class="about__ai-label">
          <span aria-hidden="true">&lt;/&gt;</span> Trabajo asistido por IA
        </p>
        <p>
          Integro herramientas como Claude y Claude Code en mi flujo de
          desarrollo para acelerar la construcción, mientras yo defino la
          arquitectura, tomo las decisiones técnicas y reviso cada línea que
          entra a producción. La IA multiplica mi productividad; el criterio y
          el diseño son míos.
        </p>
      </aside>
    </div>

    <ul class="about__focus">
      {
        focus.map((item, i) => (
          <li class="about__focus-item reveal" style={`--reveal-delay: ${i * 60}ms`}>
            <span class="about__focus-icon" aria-hidden="true">
              <Icon name={item.icon} />
            </span>
            <h3 class="about__focus-title">{item.title}</h3>
            <p class="about__focus-desc">{item.desc}</p>
          </li>
        ))
      }
    </ul>
  </div>
</section>
